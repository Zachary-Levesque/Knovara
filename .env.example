# Root environment variable reference.
#
# Copy this file to .env for local full-stack development and provide values
# shared by Docker Compose and the frontend development server.

# Public URL used by the Next.js frontend to reach the FastAPI backend.
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000

# OpenAI API key reference for local services that need model access.
OPENAI_API_KEY=

