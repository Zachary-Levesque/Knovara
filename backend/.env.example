# Backend environment variable reference.
#
# Copy this file to backend/.env for local backend development and provide
# values for the variables below before implementing runtime integrations.

# OpenAI API key used for embeddings, chat completion, and mentorship generation.
OPENAI_API_KEY=

# OpenAI chat model that will be used by mentor and chat workflows.
OPENAI_CHAT_MODEL=gpt-4o-mini

# OpenAI embedding model that will be used by the ingestion pipeline.
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# Local directory where Chroma will persist vector database files.
CHROMA_PERSIST_DIR=./.chroma

# SQLite database used for project/workspace metadata.
SQLITE_DB_PATH=./.knovara.sqlite3

# Local directory where GitHub repository checkouts are cached.
REPOSITORY_CACHE_DIR=./.repos

# Default Chroma collection used by mentor, chat, and indexing workflows.
DEFAULT_COLLECTION=seets

# Comma-separated frontend origins allowed to call the backend during development.
CORS_ORIGINS=http://localhost:3000
